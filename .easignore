# When .easignore exists, it replaces .gitignore for EAS uploads — so
# this file must include everything we'd normally gitignore plus extras.

# --- standard (mirrors .gitignore) ---
node_modules
.pnp
.pnp.js
coverage
playwright-report/
test-results/
.next/
out/
build/
dist/
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
**/*.env
**/*.env.*
!**/.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local
.turbo/
**/*.rest
cookies.txt
**/*.tsbuildinfo
.claude/

# --- EAS-specific: exclude non-mobile workspaces so they're not installed ---
apps/api/
apps/web/
apps/web-v2/
apps/ios-mockups/
apps/*.log
packages/eslint-config/
packages/ui/

# --- generated native folders (mirrors apps/mobile/.gitignore) ---
# EAS regenerates these via `expo prebuild` on the worker.
apps/mobile/ios/
apps/mobile/android/
apps/mobile/.expo/
apps/mobile/web-build/
apps/mobile/expo-env.d.ts
apps/mobile/.kotlin/
apps/mobile/.metro-health-check*
apps/mobile/*.orig.*
apps/mobile/*.jks
apps/mobile/*.p8
apps/mobile/*.p12
apps/mobile/*.key
apps/mobile/*.mobileprovision

# --- but keep packages/types/dist (gitignored but needed by mobile) ---
!packages/types/dist/

# --- large root-level docs not needed for the build ---
PRE_LAUNCH_AUDIT_*.md
PRE_LAUNCH_FIX_PLAN_*.md
STRIPE_TEST_MODE_RUNBOOK.md
STRIPE_TESTING_CHECKLIST.md
SEO-COMPARISON-REPORT.md
appstore-listing.txt
content/
pnpm-lock\ *.yaml
