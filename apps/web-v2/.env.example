# Heimursaga Web App Environment Variables
# Copy this file to .env.local and fill in the values

# App Configuration
# The public URL of this frontend (used for canonical URLs and OG tags)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# API Configuration
# The URL of the backend API server
NEXT_PUBLIC_API_URL=http://localhost:5001/v1

# Mapbox Configuration
# Get your token from https://account.mapbox.com/access-tokens/
# Required for maps, geocoding, and location features
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token_here

# Stripe Configuration
# Get your publishable key from https://dashboard.stripe.com/apikeys
# Use pk_test_* for development, pk_live_* for production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here

# Google reCAPTCHA v3 Configuration
# Get your site key from https://www.google.com/recaptcha/admin
# Leave empty to disable reCAPTCHA (disabled automatically on localhost)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Google Sign-In (OAuth 2.0 Client ID)
# Create one in Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web).
# Authorized JS origin: your NEXT_PUBLIC_APP_URL. The same CLIENT_ID goes in the API's GOOGLE_CLIENT_ID.
# Leave empty to hide the Google button.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google Analytics
# Leave empty to disable analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXX

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
