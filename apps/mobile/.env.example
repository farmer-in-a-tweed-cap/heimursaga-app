# Heimursaga Mobile — Required Environment Variables
# Copy to .env and fill in values before building.

# API base URL (include /v1 suffix)
EXPO_PUBLIC_API_URL=https://api.heimursaga.com/v1

# Stripe publishable key (pk_live_* or pk_test_*)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Mapbox public access token (pk.*)
EXPO_PUBLIC_MAPBOX_TOKEN=

# Mapbox download token — required at build time for native SDK
MAPBOX_DOWNLOADS_TOKEN=

# Sentry DSN for crash reporting
SENTRY_DSN=
