# Google OAuth (Sign in with Google)
# Create an OAuth 2.0 Client ID in Google Cloud Console → APIs & Services → Credentials.
# The same CLIENT_ID goes in the web app's NEXT_PUBLIC_GOOGLE_CLIENT_ID.
# CLIENT_SECRET is used server-side to exchange the auth code for an ID token.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

