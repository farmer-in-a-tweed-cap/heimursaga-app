SMTP_USER=
SMTP_PASSWORD=
SMTP_EMAIL_FROM=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Explorer Pro Plan - Stripe IDs (use test or live mode IDs)
